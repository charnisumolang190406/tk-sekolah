generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Murid {
  id     Int    @id @default(autoincrement())
  nama   String
  umur   Int
  kelas  String
}

model Guru {
  id    Int    @id @default(autoincrement())
  nama  String
  mapel String
}

model Pengumuman {
  id    Int    @id @default(autoincrement())
  judul String
  isi   String
  tanggal DateTime @default(now())
}

model Galeri {
  id    Int    @id @default(autoincrement())
  judul String
  foto  String
}